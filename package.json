{
  "name": "distributed-payment-system",
  "version": "1.0.0",
  "description": "Production-grade event-driven payment processing with Kafka, Redis, PostgreSQL",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "dev:workers": "tsx watch src/workers/all.workers.ts",
    "start": "node dist/server.js",
    "start:workers": "node dist/workers/all.workers.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "postinstall": "prisma generate",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest --testPathPattern=unit --runInBand",
    "test:integration": "jest --testPathPattern=integration --runInBand --forceExit",
    "test:integration:compose": "INTEGRATION_TESTS=1 jest --testPathPattern=integration --runInBand --forceExit",
    "test:stress": "jest --testPathPattern=stress --runInBand --forceExit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.3",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.1",
    "@opentelemetry/resources": "^1.30.1",
    "@opentelemetry/sdk-node": "^0.57.1",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@prisma/client": "^6.2.1",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "kafkajs": "^2.2.4",
    "nanoid": "^5.0.9",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "prom-client": "^15.1.3",
    "prisma": "^6.2.1",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "private": true
}
